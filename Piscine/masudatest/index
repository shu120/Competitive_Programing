[5] ft_putnbr
問題: int を10進で出力。負数対応。
模範解答:

#include <unistd.h>
static void putc(char c){write(1,&c,1);}
void	ft_putnbr(int n){
	long x=n; if(x<0){putc('-');x=-x;}
	if(x>=10) ft_putnbr((int)(x/10));
	putc((char)('0'+(x%10)));
}


[6] ft_strcmp
問題: strcmp と同様の比較結果を返す。
模範解答:

int	ft_strcmp(char *a,char *b){
	while(*a && *a==*b){a++;b++;}
	return ((unsigned char)*a-(unsigned char)*b);
}


[7] rot_13
問題: アルファベットは13文字回転して出力。他文字はそのまま。引数1つ以外は改行のみ。
模範解答:

#include <unistd.h>
static char r(char c){
	if(c>='a'&&c<='z') return (char)('a'+(c-'a'+13)%26);
	if(c>='A'&&c<='Z') return (char)('A'+(c-'A'+13)%26);
	return c;
}
int	main(int ac,char **av){
	int i=0; if(ac!=2){write(1,"\n",1);return 0;}
	while(av[1][i]){char x=r(av[1][i]);write(1,&x,1);i++;}
	write(1,"\n",1); return 0;
}


