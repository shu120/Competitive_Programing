[9] last_word
問題: 引数1つ。空白とタブで区切られた最後の単語だけを出力して改行。
模範解答:

#include <unistd.h>
int	main(int ac,char **av){
	int i,s,e;
	if(ac!=2){write(1,"\n",1);return 0;}
	i=0;while(av[1][i])i++;
	while(i>0 && (av[1][i-1]==' '||av[1][i-1]=='\t')) i--;
	e=i; while(i>0 && av[1][i-1]!=' ' && av[1][i-1]!='\t') i--;
	s=i; while(s<e){write(1,&av[1][s],1);s++;}
	write(1,"\n",1); return 0;
}


