}


[12] ft_range
問題: min 以上 max 未満の連続整数を格納した新規配列を返す。失敗や min>=max は NULL。
模範解答:

#include <stdlib.h>
int	*ft_range(int min,int max){
	int n=max-min,i=0,*a;
	if(min>=max) return 0;
	a=(int*)malloc(sizeof(int)*n);
	if(!a) return 0;
	while(i<n){a[i]=min+i;i++;}
	return a;
}


[13] count_words
問題: 文字列 s を空白とタブで区切った単語数を返す。
模範解答:

static int is_sep(char c){return (c==' '||c=='\t');}
int	count_words(char *s){
	int i=0,n=0;
	while(s[i]){
		while(s[i]&&is_sep(s[i])) i++;
		if(s[i]){n++; while(s[i]&&!is_sep(s[i])) i++;}
	}
	return n;
}


[14] ft_split（空白とタブを区切りとする版）
問題: 文字列を空白/タブで分割し、各単語を新規確保して char** で返す。末尾は NULL。失敗時は途中確保を解放して NULL（提出では解放不要でもよいスクールもありますが、ここは丁寧に）。
模範解答:

#include <stdlib.h>

static int	is_sep(char c){return (c==' '||c=='\t');}

static int	count_words(char *s){
	int i=0,n=0; while(s[i]){
		while(s[i]&&is_sep(s[i])) i++;
		if(s[i]){n++; while(s[i]&&!is_sep(s[i])) i++;}
	} return n;
}

static char	*dup_range(char *s,int st,int ed){
	int len=ed-st,i=0; char *p=(char*)malloc(len+1);
	if(!p) return 0; while(i<len){p[i]=s[st+i];i++;} p[len]=0; return p;
}

static void	free_all(char **v,int k){
	while(k--) free(v[k]); free(v);
}

char	**ft_split(char *s){
	int i=0,k=0,st,words=count_words(s);
	char **out=(char**)malloc(sizeof(char*)*(words+1));
	if(!out) return 0;
	while(s[i]){
		while(s[i]&&is_sep(s[i])) i++;
		if(!s[i]) break;
		st=i; while(s[i]&&!is_sep(s[i])) i++;
		out[k]=dup_range(s,st,i);
		if(!out[k]){free_all(out,k);return 0;}
		k++;
	}
	out[k]=0; return out;
}